# PostgreSQL connection string
# Local dev (matches docker-compose.yml defaults):
DATABASE_URL=postgresql://health_coach:health_coach@localhost:5432/health_coach

# Hevy API key — get from https://hevy.com/settings (Developer tab)
HEVY_API_KEY=

# Oura — get credentials from https://cloud.ouraring.com (Applications section)
# Register http://localhost:8000/oauth/oura/callback as your redirect URI in dev
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:8000/oauth/oura/callback

# Whoop — get credentials from https://developer-dashboard.whoop.com
# Register http://localhost:8000/oauth/whoop/callback as your redirect URI in dev
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/oauth/whoop/callback

# Withings — get credentials from https://developer.withings.com
# Register http://localhost:8000/oauth/withings/callback as your redirect URI in dev
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=http://localhost:8000/oauth/withings/callback

# Frontend URL — used to redirect back after OAuth (swap for your prod domain when deploying)
FRONTEND_URL=http://localhost:5173

# Anthropic
ANTHROPIC_API_KEY=

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BLOODWORK_ENCRYPTION_KEY=
