# PostgreSQL connection string
# Local dev (matches docker-compose.yml defaults):
DATABASE_URL=postgresql://health_coach:health_coach@localhost:5432/health_coach

# Hevy API key — get from https://hevy.com/settings (Developer tab)
HEVY_API_KEY=

# Oura — get credentials from https://cloud.ouraring.com (Applications section)
# Register http://localhost:8000/oauth/oura/callback as your redirect URI in dev
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:8000/oauth/oura/callback

# Whoop — get credentials from https://developer-dashboard.whoop.com
# Register http://localhost:8000/oauth/whoop/callback as your redirect URI in dev
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/oauth/whoop/callback

# Withings — get credentials from https://developer.withings.com
# Register http://localhost:8000/oauth/withings/callback as your redirect URI in dev
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=http://localhost:8000/oauth/withings/callback

# Frontend URL — used to redirect back after OAuth (swap for your prod domain when deploying)
FRONTEND_URL=http://localhost:5173

# Anthropic
ANTHROPIC_API_KEY=

# Clerk — get from https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://<your-clerk-frontend-api>/.well-known/jwks.json

# OAuth state signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
OAUTH_STATE_SECRET=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BLOODWORK_ENCRYPTION_KEY=

# Cloudflare R2 — create bucket + API token at dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=health-coach-progress-photos

# Stripe — get from https://dashboard.stripe.com/apikeys
# Register POST /webhooks/stripe in the Stripe dashboard with these events:
#   customer.subscription.created, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_failed, invoice.payment_succeeded
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
