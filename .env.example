# Hevy API key — get from https://hevy.com/settings (Developer tab)
HEVY_API_KEY=

# Whoop — get credentials from https://developer-dashboard.whoop.com
# Run `python -m sync.whoop_auth` once to populate the token fields below
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8484/callback
WHOOP_ACCESS_TOKEN=
WHOOP_REFRESH_TOKEN=

# Withings — get credentials from https://developer.withings.com
# Run `python -m sync.withings_auth` once to populate the token fields below
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=http://localhost:8585/callback
WITHINGS_ACCESS_TOKEN=   # auto-populated by withings_auth
WITHINGS_REFRESH_TOKEN=

# Cronometer (future)
CRONOMETER_API_KEY=
